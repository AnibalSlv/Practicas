@page "/"
@using Microsoft.AspNetCore.SignalR.Client;
@inject NavigationManager NavigationManager;

<PageTitle>Home</PageTitle>

<div class="form-group">
    <label>User:</label>
    <input tabindex="userInput" />
</div>

<div class="form-group">
    <label>Message:</label>
    <input type="text" @bind="messageInput" size="40" />
</div>
<button @onclick="Send" disabled="@(!IsConnected)"></button>
<br />

<ul>
    @foreach (var message in Messages)
    {
        <li>@message</li>
    }
</ul>

@code
{
    private HubConnection hubConnection;
    private List<string> Messages = new List<string>();
    private string userInput;
    private string messageInput;

    protected override async Task OnInitializedAsync()
    {
        hubConnection = new HubConnectionBuilder()
            .WithUrl(NavigationManager.ToAbsoluteUri("/chathub")) //Estableces la conexion
            .Build();

        //Aqui lo que se hara
        hubConnection.On<string, string>("ReciveMessage", (user, message) =>
        {
            var encodedMessage = $"{user}: {message}"; //Esto es lo que se va a ver
            Messages.Add(encodedMessage); // Aqui le anades la var de arriba a la lista que se muestra en HTML
            StateHasChanged(); //Es un evento que Refresca la pagina
        });

        await hubConnection.StartAsync();

    }

    Task Send() => hubConnection.SendAsync("SendMessage", userInput, messageInput); //Esta funcion es lo que esta en ChatHub.cs

    public bool IsConnected => hubConnection.State == HubConnectionState.Connected; //Esto verifica si el usuario esta conectado

    public void Dispose() //???????????????//
    {
        _ = hubConnection.DisposeAsync();
    }
}