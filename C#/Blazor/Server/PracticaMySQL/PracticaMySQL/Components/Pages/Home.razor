@page "/"
@inject PracticaMySQL.Data.Database DBConnect
@using System.Data
@using System.ComponentModel.DataAnnotations  // Para validaciones

<PageTitle>Home</PageTitle>

<h1>Hello, world!</h1>

Welcome to your new app.

<p><strong>Nombre:</strong> @nuevoActor.FirstName</p>
<p><strong>Apellido:</strong> @nuevoActor.LastName</p>
<p><strong>Fecha:</strong> @nuevoActor.Date.ToShortDateString()</p>

<h3>Agregar Actor</h3>

<input type="text" @bind-value="nuevoActor.FirstName"/>
<input type="text" @bind-value="nuevoActor.LastName"/>
<input type="date" @bind-value="nuevoActor.Date"/>
<button @onclick="GuardarActor">Guardar</button>

<h3>Lista de Actores</h3>

<table class="table">
    <thead>
        <tr>
            <th>ID</th>
            <th>Nombre</th>
            <th>Apellido</th>
            <th>Fecha de Actualización</th>
        </tr>
    </thead>
    <tbody>
        @foreach (DataRow row in dtDatos.Rows)
        {
            <tr>
                <td>@row["actor_id"]</td>
                <td>@row["first_name"]</td>
                <td>@row["last_name"]</td>
                <td>@((DateTime)row["last_update"]).ToShortDateString()</td>
            </tr>
        }
    </tbody>
</table>

@code {
    private DataTable dtDatos = new DataTable();
    private Actor nuevoActor = new Actor();
    private string mensaje = string.Empty;

    protected override void OnInitialized()
    {
        dtDatos = DBConnect.GetActor();
    }

    private async void GuardarActor()  // Cambié a async si necesitas, pero por ahora síncrono está bien
    {
        try
        {
            int resultado = DBConnect.AddActor(nuevoActor.FirstName, nuevoActor.LastName, nuevoActor.Date);
            if (resultado > 0)
            {
                mensaje = "Actor agregado exitosamente.";
                // Recargar la lista para mostrar el nuevo dato
                dtDatos = DBConnect.GetActor();
                StateHasChanged();  // Forza actualización de la UI

                // Limpiar formulario
                nuevoActor = new Actor();
            }
            else
            {
                mensaje = "Error al agregar el actor.";
            }
        }
        catch (Exception ex)
        {
            mensaje = $"Error: {ex.Message}";
        }
    }

    public class Actor
    {
        public string FirstName { get; set; } = string.Empty;

        public string LastName { get; set; } = string.Empty;

        public DateTime Date { get; set; } = DateTime.Now;
    }
}